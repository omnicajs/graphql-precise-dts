{
    "name": "@omnicajs/graphql-precise-dts",
    "description": "GraphQL files type declaration generator",
    "version": "0.1.0",
    "license": "MIT",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.cjs",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "vite build",
        "check:peer-deps": "fix-peer-deps",
        "check:peer-deps:fix": "fix-peer-deps --fix",
        "generate:test-fixtures": "ts-node tests/fixtures/generate-fixtures.ts",
        "release": "standard-version",
        "release:minor": "standard-version --release-as minor",
        "release:patch": "standard-version --release-as patch",
        "release:major": "standard-version --release-as major",
        "test:types": "vitest --typecheck run tests/types",
        "test:units": "vitest run tests/units",
        "tests": "yarn generate:test-fixtures && yarn test:types && yarn test:units",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "@graphql-typed-document-node/core": "^3.2.0",
        "graphql": "^16.12.0"
    },
    "peerDependencies": {
        "@graphql-codegen/plugin-helpers": "^6.1.0"
    },
    "devDependencies": {
        "@apollo/client": "^4.1.3",
        "@eslint/js": "^10.0.1",
        "@graphql-codegen/cli": "^6.1.1",
        "@graphql-codegen/plugin-helpers": "^6.1.0",
        "@types/node": "^25.2.0",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/eslint-plugin": "^1.6.12",
        "eslint": "^10.0.3",
        "fix-peer-deps": "^1.1.12",
        "globals": "^17.4.0",
        "rxjs": "^7.8.2",
        "standard-version": "^9.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^7.3.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.18"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "keywords": [
        "graphql",
        "graphql-codegen",
        "typescript",
        "declarations",
        "typed-document-node"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/omnicajs/graphql-precise-dts.git"
    },
    "packageManager": "yarn@4.12.0"
}
