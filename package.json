{
    "name": "graphql-precise-dts",
    "description": "GraphQL files type declaration generator",
    "version": "0.0.0",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "scripts": {
        "check:peer-deps": "fix-peer-deps",
        "check:peer-deps:fix": "fix-peer-deps --fix",
        "generate": "graphql-codegen --config graphql.codegen.ts",
        "build:plugin": "tsc -p tsconfig.codegen-plugin.json",
        "generate:custom": "yarn build:plugin && node ./generator.ts",
        "tests": "vitest --typecheck run",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "dependencies": {
        "graphql": "^16.12.0"
    },
    "devDependencies": {
        "@apollo/client": "^4.1.3",
        "@eslint/js": "^10.0.1",
        "@graphql-codegen/cli": "^6.1.1",
        "@graphql-codegen/plugin-helpers": "^6.1.0",
        "@graphql-codegen/typed-document-node": "^6.1.5",
        "@graphql-codegen/typescript": "^5.0.7",
        "@graphql-codegen/typescript-operations": "^5.0.7",
        "@types/node": "^25.2.0",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/eslint-plugin": "^1.6.12",
        "eslint": "^10.0.3",
        "fix-peer-deps": "^1.1.12",
        "globals": "^17.4.0",
        "rxjs": "^7.8.2",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "packageManager": "yarn@4.12.0"
}
